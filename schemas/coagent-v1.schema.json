{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coagent.local/schemas/coagent-v1.schema.json",
  "title": "coagent v1 Schema Registry",
  "type": "object",
  "$defs": {
    "taskId": {
      "type": "string",
      "pattern": "^TASK-[A-Za-z0-9_-]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^REQ-[A-Za-z0-9_-]+$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^[A-Za-z]:[\\\\/]" },
          { "pattern": "^/" },
          { "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)" }
        ]
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "category", "issue", "evidence", "recommendation", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["blocker", "major", "minor", "note"]
        },
        "category": { "type": "string", "minLength": 1 },
        "file": { "$ref": "#/$defs/relativePath" },
        "line": { "type": "integer", "minimum": 1 },
        "issue": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 },
        "recommendation": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "files_read": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" }
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasonix_runtime_version": { "type": "string" },
        "cache_key": { "type": "string" },
        "mcp_server_instance_id": { "type": "string" },
        "worker_id": { "type": "string" },
        "codex_session_id": { "type": "string" },
        "task_namespace": { "type": "string" },
        "tenant_id_or_user_id": { "type": "string" },
        "repo_root_realpath": { "type": "string" },
        "worktree_id": { "type": "string" },
        "base_branch": { "type": "string" },
        "snapshot_id": { "type": "string" },
        "base_revision": { "type": "string" },
        "lane": { "type": "string" },
        "project_key_hash": { "type": "string" },
        "session_key_hash": { "type": "string" },
        "static_prefix_hash": { "type": "string" }
      }
    },
    "review_diff_input_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "goal", "repo", "artifacts", "permission_level", "output_schema"],
      "properties": {
        "schema_version": { "const": "review_diff_input_v1" },
        "task_id": { "$ref": "#/$defs/taskId" },
        "request_id": { "$ref": "#/$defs/requestId" },
        "mode": { "const": "review_diff" },
        "goal": { "type": "string", "minLength": 1 },
        "repo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["root"],
          "properties": {
            "root": { "type": "string", "minLength": 1 },
            "base_branch": { "type": "string" },
            "working_branch": { "type": "string" }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["diff_path"],
          "properties": {
            "context_path": { "$ref": "#/$defs/relativePath" },
            "diff_path": { "$ref": "#/$defs/relativePath" },
            "test_log_path": { "$ref": "#/$defs/relativePath" },
            "build_log_path": { "$ref": "#/$defs/relativePath" }
          }
        },
        "focus": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_minutes": { "type": "integer", "minimum": 1 },
            "max_steps": { "type": "integer", "minimum": 1 },
            "max_output_chars": { "type": "integer", "minimum": 1 }
          }
        },
        "permission_level": { "const": "L1_DIFF_REVIEW" },
        "output_schema": { "const": "review_result_v1" }
      }
    },
    "review_result_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "task_id", "request_id", "status", "verdict", "summary", "confidence"],
      "properties": {
        "schema_version": { "const": "review_result_v1" },
        "task_id": { "$ref": "#/$defs/taskId" },
        "request_id": { "$ref": "#/$defs/requestId" },
        "status": {
          "type": "string",
          "enum": ["ok", "partial", "error", "timeout"]
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "needs_fix", "risky", "unknown", "not_applicable"]
        },
        "summary": { "type": "string" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" },
          "default": []
        },
        "tests_to_run": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "metadata": { "$ref": "#/$defs/metadata" }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/review_diff_input_v1" },
    { "$ref": "#/$defs/review_result_v1" }
  ]
}

